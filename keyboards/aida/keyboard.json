{
    "manufacturer": "Takeshi Nishio",
    "keyboard_name": "aida",
    "maintainer": "jpskenn",
    "bootloader": "rp2040",
    "diode_direction": "COL2ROW",
    "features": {
        "bootmagic": true,
        "extrakey": true,
        "mousekey": true,
        "nkro": true,
        "rgblight": true,
        "via": true
    },
    "debounce": 5,
    "dynamic_keymap": {
        "layer_count": 8
    },
    "matrix_pins": {
        "cols": ["GP6", "GP7", "GP8", "GP9", "GP10", "GP15"],
        "rows": ["GP2", "GP3", "GP4", "GP5"]
    },
    "processor": "RP2040",
    "url": "https://github.com/jpskenn/Aida/",
    "usb": {
        "device_version": "0.1.0",
        "pid": "0xB1B2",
        "vid": "0xB9DD"
    },
    "rgblight": {
        "led_count": 6,
        "split": true,
        "split_count": [3, 3],
        "max_brightness": 50,
        "animations": {
            "alternating": true,
            "breathing": true,
            "christmas": true,
            "knight": true,
            "rainbow_mood": true,
            "rainbow_swirl": true,
            "rgb_test": true,
            "snake": true,
            "static_gradient": true,
            "twinkle": true
        },
        "layers": {
            "blink": true,
            "enabled": true,
            "max": 12
        }
    },
    "ws2812": {
        "driver": "vendor",
        "pin": "GP16"
    },
    "layouts": {
        "LAYOUT": {
            "layout": [

            // ===== 左手 =====
            {"matrix":[0,0], "x":0, "y":0},
            {"matrix":[0,1], "x":1, "y":0},
            {"matrix":[0,2], "x":2, "y":0},
            {"matrix":[0,3], "x":3, "y":0},
            {"matrix":[0,4], "x":4, "y":0},

            {"matrix":[1,0], "x":0, "y":1},
            {"matrix":[1,1], "x":1, "y":1},
            {"matrix":[1,2], "x":2, "y":1},
            {"matrix":[1,3], "x":3, "y":1},
            {"matrix":[1,4], "x":4, "y":1},

            {"matrix":[2,0], "x":0, "y":2},
            {"matrix":[2,1], "x":1, "y":2},
            {"matrix":[2,2], "x":2, "y":2},
            {"matrix":[2,3], "x":3, "y":2},
            {"matrix":[2,4], "x":4, "y":2},
            {"matrix":[2,5], "x":5, "y":2},

            {"matrix":[3,2], "x":1, "y":3},
            {"matrix":[3,3], "x":2, "y":3},
            {"matrix":[3,4], "x":3, "y":3},
            {"matrix":[3,5], "x":4, "y":3},

            {"matrix":[4,1], "x":8,  "y":0},
            {"matrix":[4,2], "x":9,  "y":0},
            {"matrix":[4,3], "x":10, "y":0},
            {"matrix":[4,4], "x":11, "y":0},
            {"matrix":[4,5], "x":12, "y":0},

            {"matrix":[5,1], "x":8,  "y":1},
            {"matrix":[5,2], "x":9,  "y":1},
            {"matrix":[5,3], "x":10, "y":1},
            {"matrix":[5,4], "x":11, "y":1},
            {"matrix":[5,5], "x":12, "y":1},

            {"matrix":[6,0], "x":7,  "y":2},
            {"matrix":[6,1], "x":8,  "y":2},
            {"matrix":[6,2], "x":9,  "y":2},
            {"matrix":[6,3], "x":10, "y":2},
            {"matrix":[6,4], "x":11, "y":2},
            {"matrix":[6,5], "x":12, "y":2},

            {"matrix":[7,0], "x":8,  "y":3},
            {"matrix":[7,1], "x":9,  "y":3},
            {"matrix":[7,2], "x":10, "y":3},
            {"matrix":[7,3], "x":11, "y":3}
            ]
        }
    },
    "bootmagic": {
        "enabled": true,
        "matrix": [ 0, 0 ]
    },
    "split": {
        "enabled": true,
        "soft_serial_pin": "GP14",
        "transport": {
            "protocol": "serial"
        }
    }
}
